{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ],
  "env": {
    "TIEULAM_FRONTEND": "https://sv1.tieulam1.live",
    "TIEULAM_API": "https://api.tlap12062026.xyz",
    "TIEULAM_CDN": "https://live.secufun.xyz",
    "HOIQUAN_FRONTEND": "https://sv2.hoiquan4.live",
    "HOIQUAN_API": "https://sv.hoiquantv.xyz/api/v1/external",
    "KHANDAIA_FRONTEND": "https://tructiep.khandaia.link",
    "KHANDAIA_API": "https://sv.khandai-a.xyz/api/v1/external"
  }
}
