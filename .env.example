# ─── Relay (Replit → Vercel) ─────────────────────────────────────────────────
# URL của relay endpoint trên Replit (để Vercel bypass IP block TieuLam)
TIEULAM_RELAY_URL=https://<your-replit-domain>/api/tieulam-relay

# Secret dùng chung giữa Vercel (client) và Replit (server)
RELAY_SECRET=<your-relay-secret>

# ─── TieuLam TV ───────────────────────────────────────────────────────────────
TIEULAM_FRONTEND=https://sv1.tieulam1.live
TIEULAM_API=https://api.tlap12062026.xyz
TIEULAM_CDN=https://live.secufun.xyz

# ─── Hội Quán TV ─────────────────────────────────────────────────────────────
HOIQUAN_FRONTEND=https://sv2.hoiquan4.live
HOIQUAN_API=https://sv.hoiquantv.xyz/api/v1/external

# ─── Khán Đài A ──────────────────────────────────────────────────────────────
KHANDAIA_FRONTEND=https://tructiep.khandaia.link
KHANDAIA_API=https://sv.khandai-a.xyz/api/v1/external

# ─── Tuỳ chỉnh ───────────────────────────────────────────────────────────────
# Thời gian tối đa của 1 trận (giây), mặc định 7200 (2 giờ)
# MATCH_MAX_DURATION=7200

# Override URL EPG nếu muốn dùng external EPG
# EPG_URL=https://example.com/epg.xml

# URL public của server (tự phát hiện nếu để trống)
# APP_URL=https://your-vercel-app.vercel.app
